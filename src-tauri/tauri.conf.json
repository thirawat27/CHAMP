{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CHAMP",
  "version": "1.1.0",
  "identifier": "dev.thirawat27.champ",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CHAMP By Thirawat27",
        "width": 1080,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "devtools": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' http://localhost:* ws://localhost:* https://tauri.localhost;"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["MANUAL.html", "runtime-config.json", "runtime-config.schema.json"],
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "15.0"
    }
  }
}
